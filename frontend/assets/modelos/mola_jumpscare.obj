# Modelo Low-Poly PS1: Mola e Placa de Jump Scare
# ==========================================
o Mola_Espirada
# --- Helice Ribbon Simples (R=0.5, Altura 3.5, 10 Segments) ---
# Pivô na base (0,0,0)
v 0.5000 0.0000 0.0000
v 0.3500 0.0000 0.0000
v 0.0000 0.3500 0.5000
v 0.0000 0.3500 0.3500
v -0.5000 0.7000 0.0000
v -0.3500 0.7000 0.0000
v 0.0000 1.0500 -0.5000
v 0.0000 1.0500 -0.3500
v 0.5000 1.4000 0.0000
v 0.3500 1.4000 0.0000
v 0.0000 1.7500 0.5000
v 0.0000 1.7500 0.3500
v -0.5000 2.1000 0.0000
v -0.3500 2.1000 0.0000
v 0.0000 2.4500 -0.5000
v 0.0000 2.4500 -0.3500
v 0.5000 2.8000 0.0000
v 0.3500 2.8000 0.0000
v 0.0000 3.1500 0.5000
v 0.0000 3.1500 0.3500
# Vértices de conexão final no topo da mola (onde a placa encosta)
v -0.2000 3.5000 0.0000
v 0.2000 3.5000 0.0000
v 0.2000 3.5000 0.1000
v -0.2000 3.5000 0.1000
# --- Faces da Mola ---
f 1 3 4 2
f 3 5 6 4
f 5 7 8 6
f 7 9 10 8
f 9 11 12 10
f 11 13 14 12
f 13 15 16 14
f 15 17 18 16
f 17 19 20 18
f 19 21 22 20
f 21 23 24 22

# ==========================================
o Placa_JumpScare
# --- Retangulo vertical para texturas 2D (4x5, Pivô na base Y=3.5) ---
v -2.0000 3.5000 0.0500
v 2.0000 3.5000 0.0500
v 2.0000 8.5000 0.0500
v -2.0000 8.5000 0.0500
# Coordenadas UV para mapear o monstro 2D perfeitamente
vt 0.0000 0.0000
vt 1.0000 0.0000
vt 1.0000 1.0000
vt 0.0000 1.0000
# Face da placa (visível de frente para o jogador)
f 25/1 26/2 27/3 28/4
