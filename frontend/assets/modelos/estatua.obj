# Modelo Low-Poly PS1: Entidade 2 (A Estatua)
o Estatua_Humanoide
# --- Vertices: Pernas / Base (Bloco unico para parecer pedra macica Y=0 a Y=2.5) ---
v -0.5000 0.0000 -0.4000
v 0.5000 0.0000 -0.4000
v 0.5000 0.0000 0.4000
v -0.5000 0.0000 0.4000
v -0.5000 2.5000 -0.4000
v 0.5000 2.5000 -0.4000
v 0.5000 2.5000 0.4000
v -0.5000 2.5000 0.4000
# --- Vertices: Torso e Bracos colados (Y=2.5 a Y=5.0) ---
v -0.7000 2.5000 -0.5000
v 0.7000 2.5000 -0.5000
v 0.7000 2.5000 0.5000
v -0.7000 2.5000 0.5000
v -0.7000 5.0000 -0.5000
v 0.7000 5.0000 -0.5000
v 0.7000 5.0000 0.5000
v -0.7000 5.0000 0.5000
# --- Vertices: Cabeca (Y=5.0 a Y=6.0) ---
v -0.4000 5.0000 -0.4000
v 0.4000 5.0000 -0.4000
v 0.4000 5.0000 0.4000
v -0.4000 5.0000 0.4000
v -0.4000 6.0000 -0.4000
v 0.4000 6.0000 -0.4000
v 0.4000 6.0000 0.4000
v -0.4000 6.0000 0.4000
# --- Coordenadas UV Mapeadas ---
vt 0.0000 0.0000
vt 1.0000 0.0000
vt 1.0000 1.0000
vt 0.0000 1.0000
# --- Faces da Base/Pernas ---
f 1/1 2/2 6/3 5/4
f 2/1 3/2 7/3 6/4
f 3/1 4/2 8/3 7/4
f 4/1 1/2 5/3 8/4
# --- Faces do Torso ---
f 9/1 10/2 14/3 13/4
f 10/1 11/2 15/3 14/4
f 11/1 12/2 16/3 15/4
f 12/1 9/2 13/3 16/4
f 5/1 8/2 12/3 9/4
f 6/1 5/2 9/3 10/4
# --- Faces da Cabeca ---
f 17/1 18/2 22/3 21/4
f 18/1 19/2 23/3 22/4
f 19/1 20/2 24/3 23/4
f 20/1 17/2 21/3 24/4
f 21/1 22/2 23/3 24/4
